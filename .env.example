OPENAI_API_KEY=sk-your-key-here
PORT=5000
COOPER_APP_PASSWORD=replace-with-a-long-random-password
COOPER_SESSION_SECRET=replace-with-a-different-long-random-secret
COOPER_SESSION_TTL_HOURS=168
# Optional data-store override for isolated development or integration tests.
COOPER_DATA_DIR=
ARCADE_API_KEY=
ARCADE_USER_ID=michael@example.com
ARCADE_MCP_GATEWAY_URL=https://api.arcade.dev/mcp/cooper-app
ARCADE_SEARCH_WORKSPACE_TOOL=
ARCADE_NOTION_SEARCH_TOOL=
ARCADE_NOTION_FETCH_PAGE_TOOL=
ARCADE_NOTION_METADATA_TOOL=NotionToolkit.GetObjectMetadata
ARCADE_CALENDAR_EVENTS_TOOL=GoogleCalendar.ListEvents
ARCADE_CUSTOMER_CONTEXT_TOOL=
ARCADE_ENGINEERING_CONTEXT_TOOL=
ARCADE_CREATE_FOLLOWUP_TOOL=
COOPER_ENABLE_ARCADE_WRITES=false
COOPER_TIME_ZONE=America/Vancouver
COOPER_TODAY_CACHE_SECONDS=120
COOPER_NOTION_SPRINT_ANCHOR_PAGE_ID=39c5efcc-eccd-8038-a3b7-f874099756ba
COOPER_NOTION_SPRINT_DATABASE_ID=6772d5ef-4e05-49b4-b41b-a5286f0f4cfa
# Optional override. When blank, Cooper follows the Sprint relation on the anchor task.
COOPER_NOTION_ACTIVE_SPRINT_ID=
COOPER_DAILY_BRIEF_HOUR=7
COOPER_DAILY_BRIEF_ASSIGNEES=Michael Moll,michael@aires.ai,michael
# Optional iOS remote delivery. Keep the .p8 key outside the repository and prefer the path setting.
COOPER_APNS_KEY_ID=
COOPER_APNS_TEAM_ID=
COOPER_APNS_BUNDLE_ID=ai.aires.cooper.mobile
COOPER_APNS_ENVIRONMENT=sandbox
COOPER_APNS_PRIVATE_KEY_PATH=
# Full TeamID.BundleID value used by the AASA file, for example ABC1234567.ai.aires.cooper.mobile.
COOPER_IOS_ASSOCIATED_APP_ID=
COOPER_MCP_APP_SERVERS={"mcpServers":{"Cooper":{"url":"https://api.arcade.dev/mcp/cooper-app"}}}
# Zoom Meeting SDK app credentials enable embedded same-account participant join in every web Cooper session.
ZOOM_SDK_KEY=
ZOOM_SDK_SECRET=
# Keep false until Cooper implements Zoom user attribution and a host ZAK flow.
ZOOM_ENABLE_HOST_ROLE=false
NOTION_API_KEY=
NOTION_VERSION=2026-03-11
NOTION_SEARCH_LIMIT=5
NOTION_BLOCK_LIMIT=50
COOPER_WORK_MODEL=gpt-5.4
COOPER_FALLBACK_WORK_MODEL=
# First-class typed session chat. Defaults to COOPER_WORK_MODEL when blank.
COOPER_CHAT_MODEL=
COOPER_CHAT_MAX_OUTPUT_TOKENS=1800
COOPER_CHAT_MAX_TOOL_ROUNDS=8
COOPER_GSTACK_MODEL=gpt-5.4
COOPER_GSTACK_MAX_OUTPUT_TOKENS=2200
COOPER_GSTACK_INPUT_MAX_CHARS=32000
COOPER_GSTACK_CONTEXT_MAX_CHARS=24000
COOPER_JOB_DELAY_MS=15000
COOPER_JOB_MAX_ATTEMPTS=3
COOPER_JOB_MAX_OUTPUT_TOKENS=9000
COOPER_PROJECT_CONTEXT_CHARS=18000
COOPER_PROJECT_SOURCE_MAX_CHARS=250000
COOPER_PROJECT_UPLOAD_MAX_MB=20
COOPER_CONTEXT_PACKET_MAX_CHARS=36000
COOPER_CONTEXT_SEARCH_LIMIT=50
# Local-only plan handoff used by integrations/chat-with-plan. Generate a long random value.
COOPER_INGEST_TOKEN=
COOPER_PLAN_INGEST_MAX_CHARS=120000
AIRES_EXAMPLES_DIR=
COOPER_PTT_TOKEN=replace-with-a-long-random-local-token
COOPER_PTT_MAX_AUDIO_MB=18
COOPER_PTT_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
COOPER_PTT_RESPONSE_MAX_OUTPUT_TOKENS=1200
COOPER_PTT_HOTKEY=control+option+space
COOPER_VISION_CLICK_MODEL=gpt-5.4
COOPER_COMPUTER_USE_ALLOWED_APPS=Spotify,Claude,Claude Code,Google Chrome,Safari,Slack,Notion,Finder,Terminal,Visual Studio Code,Codex
